# ─────────────────────────────────────────────────────────────
# Camp Sambhar Resort — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Payload secret — used to sign JWTs / encrypt fields. Generate a long random string.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public site URL (used for canonicals, sitemap, OG, absolute links).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# Local dev uses SQLite by default (no setup). For Postgres (prod),
# set DATABASE_URI to a postgres connection string and it will be used.
# SQLite example (default):  file:./camp-sambhar.db
# Postgres example:          postgres://user:pass@host:5432/dbname
DATABASE_URI=file:./camp-sambhar.db

# ── Media / object storage (production) ──────────────────────
# Leave blank in local dev to store uploads on the local disk.
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
# Public hostname images are served from (for next/image remotePatterns).
NEXT_PUBLIC_MEDIA_HOSTNAME=

# ── Enquiry pipeline ─────────────────────────────────────────
# Resend API key for transactional email (leave blank to skip email in dev).
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=reservations@campsambhar.com
ENQUIRY_FROM_EMAIL=no-reply@campsambhar.com

# Cloudflare Turnstile (spam protection). Leave blank to disable in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Integrations ─────────────────────────────────────────────
# Stayflexi property id (also editable in SiteSettings; env is a fallback).
NEXT_PUBLIC_STAYFLEXI_PROPERTY_ID=
